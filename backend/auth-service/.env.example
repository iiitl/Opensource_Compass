# ─────────────────────────────────────────────────────────────
# Auth Service — Environment Variables
# Copy this file: cp .env.example .env
# Only fill in values that are marked REQUIRED.
# ─────────────────────────────────────────────────────────────

# REQUIRED — GitHub OAuth App credentials
# Create one at https://github.com/settings/developers
# Callback URL must be: http://localhost:8080/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# REQUIRED — JWT signing secret (shared with core_service — must be identical)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long

# REQUIRED — The URL of the core service (used to persist user data after login)
# Default: http://core_service:8083 (inside Docker)
# For local (non-Docker) dev: http://localhost:8083
CORE_SERVICE_URL=http://core_service:8083

# REQUIRED — Where the browser is redirected after a successful GitHub OAuth login
FRONTEND_URL=http://localhost:3000

# Auth service listen port (default: 8080, no need to change)
PORT=8080
