# ─────────────────────────────────────────────────────────────
# AI Service — Environment Variables
# Copy this file: cp .env.example .env
# ─────────────────────────────────────────────────────────────

# REQUIRED — Choose your LLM provider: "groq" or "gemini"
# Groq is recommended (free, fast). Sign up at https://console.groq.com
LLM_PROVIDER=groq

# Model to use. Do NOT change unless you know what you're doing.
# Groq recommended model (mixtral was decommissioned):
LLM_MODEL=llama-3.3-70b-versatile

# REQUIRED if using Groq — get your API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# REQUIRED if using Gemini — get your API key at https://aistudio.google.com
# Leave this blank / as placeholder if you are using Groq.
GEMINI_API_KEY=your_gemini_api_key

# AI service listen port (default: 8082, no need to change)
AI_SERVICE_PORT=8082
