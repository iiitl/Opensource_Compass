# ─────────────────────────────────────────────────────────────
# Core Service — Environment Variables
# Copy this file: cp .env.example .env
# Only fill in values marked REQUIRED.
# ─────────────────────────────────────────────────────────────

# REQUIRED — Supabase PostgreSQL connection string
# Dashboard → Settings → Database → Connection string → URI mode
# Replace [YOUR-PASSWORD] with your database password
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# REQUIRED — JWT secret (must be IDENTICAL to the one in auth-service)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long

# Service URLs (defaults work when running via Docker Compose)
# Change to http://localhost:808X if running services locally (without Docker)
GITHUB_SERVICE_URL=http://github-service:8081
AI_SERVICE_URL=http://ai-service:8082
NOTIFICATION_SERVICE_URL=http://notification-service:8084

# REQUIRED — URL of the frontend (used for CORS)
FRONTEND_URL=http://localhost:3000

# Core service listen port (default: 8083, no need to change)
SERVER_PORT=8083
