# ─────────────────────────────────────────────────────────────
# Notification Service — Environment Variables
# Copy this file: cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Notification service listen port (default: 8084, no need to change)
PORT=8084

# Note: This service has no external API keys.
# It only broadcasts WebSocket messages to connected browser clients
# when the core service detects new issues in watched repositories.
