# ─────────────────────────────────────────────────────────────
# GitHub Service — Environment Variables
# Copy this file: cp .env.example .env
# ─────────────────────────────────────────────────────────────

# REQUIRED — GitHub Personal Access Token
# This gives you 5,000 API requests/hour instead of 60 (unauthenticated).
# Create one at: https://github.com/settings/tokens
# Required scopes: "public_repo" (read-only is fine)
GITHUB_TOKEN=your_github_personal_access_token

# REQUIRED — URL of the frontend (used for CORS)
FRONTEND_URL=http://localhost:3000

# GitHub service listen port (default: 8081, no need to change)
PORT=8081
