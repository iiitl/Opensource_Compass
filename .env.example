# ─────────────────────────────────────────────────────────────
# 🗄️  Database — Supabase PostgreSQL
# ─────────────────────────────────────────────────────────────
# 1. Go to https://supabase.com and create a free project.
# 2. In your project dashboard → Settings → Database → Connection string
# 3. Choose "URI" mode and copy the connection string.
# 4. Replace [YOUR-PASSWORD] with the database password you set.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─────────────────────────────────────────────────────────────
# 🔐 GitHub OAuth App
# ─────────────────────────────────────────────────────────────
# 1. Go to https://github.com/settings/developers → "New OAuth App"
# 2. Set:
#    Application name : Opensource Compass (or anything you like)
#    Homepage URL     : http://localhost:3000
#    Callback URL     : http://localhost:8080/auth/github/callback
# 3. Click "Register application", then copy the Client ID.
# 4. Click "Generate a new client secret" and copy it.
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# A GitHub Personal Access Token (for higher API rate limits: 5000 req/hr vs 60)
# Create one at: https://github.com/settings/tokens (select "public_repo" scope)
GITHUB_TOKEN=your_github_personal_access_token

# ─────────────────────────────────────────────────────────────
# 🔑 JWT Secret
# ─────────────────────────────────────────────────────────────
# Must be at least 32 characters long.
# Generate a secure one with: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long

# ─────────────────────────────────────────────────────────────
# 🤖 AI Provider
# ─────────────────────────────────────────────────────────────
# Choose "groq" (recommended — free, fast) or "gemini".
# Groq  → https://console.groq.com/keys  (free account, instant API key)
# Gemini→ https://aistudio.google.com/   (optional, only if using Gemini)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key   # Leave as-is if using Groq

# ─────────────────────────────────────────────────────────────
# 🌐 Frontend — Service URLs (used by Next.js browser-side code)
# ─────────────────────────────────────────────────────────────
# These tell the browser where each backend service lives.
# Do NOT change these unless you are changing the default ports.
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:8080
NEXT_PUBLIC_CORE_SERVICE_URL=http://localhost:8083
NEXT_PUBLIC_GITHUB_SERVICE_URL=http://localhost:8081

# ─────────────────────────────────────────────────────────────
# 🔗 Auth Redirect
# ─────────────────────────────────────────────────────────────
# Where GitHub sends the user after a successful OAuth login.
# Do NOT change this unless you change the frontend port.
AUTH_REDIRECT_URL=http://localhost:3000/auth/success